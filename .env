# Spec enforcement defaults
SPEC_CODE_MAX_LINES=150
SPEC_DOCS_MAX_LINES=500
SPEC_CODE_EXTENSIONS=.js,.css
SPEC_DOCS_EXTENSIONS=.md
SPEC_IGNORE_DIRS=node_modules,src/vendor,.git,.configs

# Server
PORT=3000

# Stripe (get test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS
DYNAMODB_TABLE=staticart

# Build pipeline (Phase 5)
BUILD_HOOK_URL=

# CORS
SITE_ORIGIN=*

# Build
SITE_URL=http://localhost:3000
